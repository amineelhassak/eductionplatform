# ======================
# Server
# ======================
PORT=4000
NODE_ENV=development

# ======================
# Database (PostgreSQL)
# ======================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/platformlearning?schema=public"

# ======================
# JWT
# ======================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ======================
# Firebase Admin SDK
# ======================
# Option 1: Path to your service account key JSON file
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"

# Option 2: Inline credentials (use these if you don't want a separate file)
# FIREBASE_PROJECT_ID="your-project-id"
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"

# ======================
# CORS
# ======================
FRONTEND_URL="http://localhost:5173"
